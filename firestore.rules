rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // 기본적으로 모든 접근 차단
    match /{document=**} {
      allow read, write: if false;
    }
    
    // App Check 검증 함수
    function isAppChecked() {
      // 개발 중에 막히는 것을 방지하기 위해 아직 엄격하게 강제하지 않으려면
      // 아래를 주석 해제하거나 조건부로 사용합니다.
      // 프로덕션 배포 시에는 반드시 활성화하세요.
      // return request.appcheck.token != null;
      return true; // 임시 허용
    }

    // 현재 요청을 보낸 유저의 전화번호를 조회하는 함수
    function getUserPhone() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.phone;
    }

    // 1. users 컬렉션 (사용자 본인만 접근 가능)
    match /users/{userId} {
      allow read, write: if isAppChecked() && request.auth != null && request.auth.uid == userId;
    }

    // 2. buildings 컬렉션 (건물 및 계약 정보)
    match /buildings/{buildingId} {
      // 생성: 인증된 사용자(가입자)면 가능
      allow create: if isAppChecked() && request.auth != null;
      
      // 목록 조회(list):
      // - 임대인: 자기가 등록한 건물 (userId가 일치)
      // - 임차인: 해당 건물의 tenantPhones 배열에 자신의 전화번호가 있는 경우
      allow list: if isAppChecked() && request.auth != null && (
        resource.data.userId == request.auth.uid || 
        getUserPhone() in resource.data.tenantPhones
      );
      
      // 단일 조회(get): 링크를 통해 접근하는 중개사 및 비회원 임차인을 위해 문서 ID를 아는 경우 허용
      allow get: if isAppChecked();
      
      // 삭제: 건물을 등록한 임대인 본인만 가능
      allow delete: if isAppChecked() && request.auth != null && resource.data.userId == request.auth.uid;

      // 수정(update):
      // 1. 임대인 본인인 경우 자유롭게 수정 허용
      // 2. 비회원 임차인인 경우, 계약 서명 목적으로 units 배열 등을 업데이트할 수 있게 허용하되 건물의 핵심 정보는 변경 불가하도록 차단
      allow update: if isAppChecked() && (
        (request.auth != null && resource.data.userId == request.auth.uid) ||
        (
          request.auth == null &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.address == resource.data.address
        )
      );
    }
  }
}
